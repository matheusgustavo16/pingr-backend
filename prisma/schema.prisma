generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  name      String
  email     String     @unique
  password  String?
  picture   String?
  status    UserStatus @default(AVAILABLE)

  twoFactor        TwoFactor[]
  ownedCompanies   Company[]         @relation("CompanyOwner")
  memberships      CompanyMember[]
  chatMessages     ChatMessage[]
  chatReadStates   ChatReadState[]
  chatParticipants ChatParticipant[]

  @@map("users")
}

model TwoFactor {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pending         Boolean  @default(true)
  authTag         String
  type            String // "TOTP", "SMS", etc
  secretEnc       String // segredo encriptado
  secretNonce     String? // se usar AES-GCM
  backupCodesHash String? // pode ser JSON com hashes

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("two_factors")
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  cnpj      String?  @unique
  picture   String?

  ownerId    String
  owner      User            @relation("CompanyOwner", fields: [ownerId], references: [id])
  members    CompanyMember[]
  rooms      Room[]
  categories RoomCategory[]

  @@map("companies")
}

model CompanyMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  role   CompanyRole  @default(MEMBER)
  status MemberStatus @default(ACTIVE)

  userId    String
  companyId String

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("company_members")
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
  FINANCE
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  PENDING
}

model RoomCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emoji     String
  title     String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  rooms Room[]

  @@map("room_categories")
}

model Room {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  type      RoomTypes @default(OFFICE)
  title     String

  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  categoryId  String?
  category    RoomCategory? @relation(fields: [categoryId], references: [id])
  chatChannel ChatChannel?

  @@map("rooms")
}

enum RoomTypes {
  AUDITORIUM
  OFFICE
  MEETING
  CHAT
  ADVISORY
  VOICE
}

enum UserStatus {
  AVAILABLE
  BUSY
  IN_MEETING
  AWAY
  FOCUS
  CODING
  REVIEWING
}

model ChatChannel {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  isArchived Boolean @default(false)

  messages         ChatMessage[]
  chatReadStates   ChatReadState[]
  chatParticipants ChatParticipant[]

  @@unique([roomId])
  @@map("chat_channels")
}

model ChatMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content String
  type    MessageType @default(TEXT)

  authorId  String
  channelId String

  author  User        @relation(fields: [authorId], references: [id])
  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  isEdited  Boolean @default(false)
  isDeleted Boolean @default(false)
  isPinned  Boolean @default(false)

  @@index([channelId, createdAt])
  @@index([channelId, isPinned])
  @@map("chat_messages")
}

enum MessageType {
  TEXT
  SYSTEM
  BOT
}

model ChatReadState {
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt

  userId    String
  channelId String

  lastReadMessageId String?

  user    User        @relation(fields: [userId], references: [id])
  channel ChatChannel @relation(fields: [channelId], references: [id])

  @@unique([userId, channelId])
  @@map("chat_read_states")
}

model ChatParticipant {
  id       String   @id @default(uuid())
  joinedAt DateTime @default(now())

  role ChatRole @default(MEMBER)

  userId    String
  channelId String

  user    User        @relation(fields: [userId], references: [id])
  channel ChatChannel @relation(fields: [channelId], references: [id])

  @@unique([userId, channelId])
  @@map("chat_participants")
}

enum ChatRole {
  ADMIN
  MEMBER
  READ_ONLY
}
