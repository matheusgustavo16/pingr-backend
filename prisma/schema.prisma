generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  email     String   @unique
  password  String?
  picture   String?

  twoFactor      TwoFactor[]
  ownedCompanies Company[]       @relation("CompanyOwner")
  memberships    CompanyMember[]

  @@map("users")
}

model TwoFactor {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pending         Boolean  @default(true)
  authTag         String
  type            String // "TOTP", "SMS", etc
  secretEnc       String // segredo encriptado
  secretNonce     String? // se usar AES-GCM
  backupCodesHash String? // pode ser JSON com hashes

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("two_factors")
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  cnpj      String?  @unique
  picture   String?

  ownerId    String
  owner      User            @relation("CompanyOwner", fields: [ownerId], references: [id])
  members    CompanyMember[]
  rooms      Room[]
  categories RoomCategory[]

  @@map("companies")
}

model CompanyMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  role   CompanyRole  @default(MEMBER)
  status MemberStatus @default(ACTIVE)

  userId    String
  companyId String

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("company_members")
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
  FINANCE
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  PENDING
}

model RoomCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emoji     String
  title     String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  rooms Room[]

  @@map("room_categories")
}

model Room {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  type      RoomTypes @default(OFFICE)
  title     String

  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  categoryId String?
  category   RoomCategory? @relation(fields: [categoryId], references: [id])

  @@map("rooms")
}

enum RoomTypes {
  AUDITORIUM
  OFFICE
  MEETING
  CHAT
  ADVISORY
  VOICE
}
