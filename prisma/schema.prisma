generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lastSeenAt  DateTime?
  name        String
  email       String     @unique
  password    String?
  picture     String?
  status      UserStatus @default(AVAILABLE)
  locale      String     @default("pt-BR")
  preferences Json       @default("{}")

  twoFactor             TwoFactor[]
  ownedCompanies        Company[]           @relation("CompanyOwner")
  memberships           CompanyMember[]
  chatMessages          ChatMessage[]
  chatReadStates        ChatReadState[]
  chatParticipants      ChatParticipant[]
  createdScheduleEvents ScheduleEvent[]     @relation("ScheduleEventCreator")
  integrations          Integration[]
  notifications         Notification[]
  startedCallSessions   CallSession[]       @relation("CallSessionStarter")
  transcriptSegments    TranscriptSegment[]
  agentActionLogs       AgentActionLog[]
  createdTasks          Task[]              @relation("TaskCreator")
  assignedTasks         TaskAssignee[]      @relation("TaskAssignee")
  watchedTasks          TaskWatcher[]       @relation("TaskWatcher")
  taskComments          TaskComment[]       @relation("TaskCommentAuthor")
  taskAttachments       TaskAttachment[]    @relation("TaskAttachmentUploader")
  taskActivities        TaskActivity[]      @relation("TaskActivityActor")
  createdFolders        Folder[]            @relation("FolderCreator")
  uploadedDocuments     Document[]          @relation("DocumentUploader")
  createdAgents         Agent[]
  createdConversations  AgentConversation[]

  @@map("users")
}

model TwoFactor {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pending         Boolean  @default(true)
  authTag         String
  type            String // "TOTP", "SMS", etc
  secretEnc       String // segredo encriptado
  secretNonce     String? // se usar AES-GCM
  backupCodesHash String? // pode ser JSON com hashes

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("two_factors")
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  cnpj      String?  @unique
  picture   String?

  ownerId        String
  owner          User                @relation("CompanyOwner", fields: [ownerId], references: [id])
  members        CompanyMember[]
  rooms          Room[]
  categories     RoomCategory[]
  scheduleEvents ScheduleEvent[]
  workspaces     Workspace[]
  chatBots       ChatBot[]
  tasks          Task[]
  decorations    OfficeDecoration[]
  folders        Folder[]
  documents      Document[]
  agents         Agent[]
  conversations  AgentConversation[]

  @@map("companies")
}

// Itens puramente decorativos do mapa (ex: planta) — posicionáveis pelo admin
// no modo editor, mas sem nenhuma interação pro usuário comum (não é Room).
model OfficeDecoration {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  type      String   @default("plant")
  x         Float
  y         Float
  scale     Int      @default(1)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@map("office_decorations")
}

model Workspace {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  emoji     String
  picture   String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // GitHub integration
  githubRepoId       Int?
  githubRepoName     String?
  githubRepoFullName String?
  githubRepoUrl      String?
  githubWebhookId    Int?

  roomCategories RoomCategory[]
  rooms          Room[]
  tasks          Task[]
  folders        Folder[]
  documents      Document[]

  @@map("workspaces")
}

model CompanyMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  role   CompanyRole  @default(MEMBER)
  status MemberStatus @default(ACTIVE)

  userId    String
  companyId String

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("company_members")
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
  FINANCE
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  PENDING
}

model RoomCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emoji     String
  title     String

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  rooms          Room[]
  agents         Agent[]
  scheduleEvents ScheduleEvent[]
  tasks          Task[]
  documents      Document[]

  @@map("room_categories")
}

model Room {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  type      RoomTypes @default(OFFICE)
  title     String
  isOpen    Boolean   @default(false)
  x         Float?
  y         Float?
  // Posição na lista de canais da sidebar, dentro da categoria — não tem
  // relação com x/y (posição no mapa).
  order     Int       @default(0)

  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  workspaceId    String?
  workspace      Workspace?      @relation(fields: [workspaceId], references: [id])
  categoryId     String?
  category       RoomCategory?   @relation(fields: [categoryId], references: [id])
  chatChannel    ChatChannel?
  scheduleEvents ScheduleEvent[] @relation("ScheduleEventRoom")

  eventRefId     String?        @unique
  scheduledEvent ScheduleEvent? @relation("RoomScheduledEvent", fields: [eventRefId], references: [id])

  callSessions CallSession[]

  @@map("rooms")
}

enum RoomTypes {
  AUDITORIUM
  OFFICE
  MEETING
  CHAT
  ADVISORY
  VOICE
  DEV
  PINGUELO
}

enum UserStatus {
  AVAILABLE
  BUSY
  IN_MEETING
  AWAY
  FOCUS
  CODING
  REVIEWING
}

model ChatChannel {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  isArchived Boolean @default(false)

  messages         ChatMessage[]
  chatReadStates   ChatReadState[]
  chatParticipants ChatParticipant[]

  @@unique([roomId])
  @@map("chat_channels")
}

model ChatBot {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  name      String
  provider  String   @default("pingr")
  picture   String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  messages ChatMessage[]
  agent    Agent?

  @@map("chat_bots")
}

enum AgentKind {
  SYSTEM // bot único da plataforma ("Pinguelo"), companyId null, singleton
  TEMPLATE // catálogo de templates, companyId null, não invocável direto
  COMPANY // instância de uma empresa, criada a partir de template ou do zero
}

enum AgentLLMProvider {
  ANTHROPIC
  OPENAI
  DEEPSEEK
}

model Agent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kind     AgentKind @default(COMPANY)
  isActive Boolean   @default(true)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  templateId String?
  template   Agent?  @relation("AgentTemplateInstances", fields: [templateId], references: [id], onDelete: SetNull)
  instances  Agent[] @relation("AgentTemplateInstances")

  // Categoria da empresa a que este agente está associado (opcional)
  categoryId String?
  category   RoomCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Persona / DNA
  name        String
  age         Int?
  avatarUrl   String?
  specialty   String
  philosophy  String?
  jobFunction String

  // Provider/model por agente — sobrepõe o default de env. Não confundir
  // com ChatBot.provider (marcador de identidade de chat, valores diferentes).
  provider AgentLLMProvider @default(ANTHROPIC)
  model    String?

  // Escopo de tools que este agente pode chamar (nomes de ToolDef.name)
  allowedTools  String[] @default([])
  // Reservado para v2 (triggers automáticos/autônomos) — não usado no v1
  triggerConfig Json?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  chatBotId String?  @unique
  chatBot   ChatBot? @relation(fields: [chatBotId], references: [id])

  actionLogs           AgentActionLog[]
  conversationMessages AgentConversationMessage[]

  @@index([companyId])
  @@index([kind])
  @@index([categoryId])
  @@map("agents")
}

enum ConversationVisibility {
  PRIVATE
  PUBLIC
}

enum MessageRole {
  USER
  ASSISTANT
}

model AgentConversation {
  id         String                 @id @default(uuid())
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  title      String                 @default("Nova conversa")
  visibility ConversationVisibility @default(PRIVATE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  messages AgentConversationMessage[]

  @@index([companyId, createdById])
  @@index([companyId, visibility])
  @@map("agent_conversations")
}

model AgentConversationMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    MessageRole
  content String

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  toolName     String?
  toolArgs     Json?
  toolResult   Json?
  status       AgentActionStatus @default(SUCCESS)
  errorMessage String?

  @@index([conversationId, createdAt])
  @@map("agent_conversation_messages")
}

model ChatMessage {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  isEdited  Boolean     @default(false)
  isDeleted Boolean     @default(false)
  isPinned  Boolean     @default(false)
  type      MessageType @default(TEXT)
  content   String
  metadata  Json?       @default("{}")

  authorId  String?
  author    User?       @relation(fields: [authorId], references: [id])
  botId     String?
  bot       ChatBot?    @relation(fields: [botId], references: [id])
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  /// Espelho em Documentos quando type = FILE — cascade remove o Document
  /// quando a mensagem some (mesmo contrato do TaskAttachment).
  document Document?

  @@index([channelId, createdAt])
  @@index([channelId, isPinned])
  @@index([botId])
  @@map("chat_messages")
}

enum MessageType {
  TEXT
  SYSTEM
  BOT
  FILE
}

model ChatReadState {
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt

  userId    String
  channelId String

  lastReadMessageId String?

  user    User        @relation(fields: [userId], references: [id])
  channel ChatChannel @relation(fields: [channelId], references: [id])

  @@unique([userId, channelId])
  @@map("chat_read_states")
}

model ChatParticipant {
  id       String   @id @default(uuid())
  joinedAt DateTime @default(now())

  role ChatRole @default(MEMBER)

  userId    String
  channelId String

  user    User        @relation(fields: [userId], references: [id])
  channel ChatChannel @relation(fields: [channelId], references: [id])

  @@unique([userId, channelId])
  @@map("chat_participants")
}

enum ChatRole {
  ADMIN
  MEMBER
  READ_ONLY
}

model LinkPreview {
  id          String   @id @default(uuid())
  url         String   @unique
  title       String?
  description String?
  image       String?
  siteName    String?
  failed      Boolean  @default(false)
  fetchedAt   DateTime @default(now())

  @@map("link_previews")
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventExceptionAction {
  CANCELLED
  MODIFIED
}

model ScheduleEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title String

  startAt DateTime
  endAt   DateTime

  visibility EventVisibility @default(PUBLIC)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  roomId String?
  room   Room?   @relation("ScheduleEventRoom", fields: [roomId], references: [id])

  roomByEventRef Room? @relation("RoomScheduledEvent")

  // Categoria da empresa a que este evento está associado (opcional)
  categoryId String?
  category   RoomCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("ScheduleEventCreator", fields: [createdById], references: [id])

  provider   String? // ex: "google", "outlook", etc
  externalId String? // ID do evento no calendário externo

  // Recorrência (RFC 5545 / RRULE) — nunca materializamos ocorrências
  // futuras no banco. Este registro é sempre o evento "mestre" (a primeira
  // ocorrência); as demais são geradas sob demanda a partir de startAt +
  // recurrenceRule, dentro do range pedido pelo cliente.
  isRecurring     Boolean   @default(false)
  recurrenceRule  String? // ex: "FREQ=WEEKLY;BYDAY=MO,WE" — sem DTSTART/UNTIL embutidos
  recurrenceUntil DateTime? // limite opcional da recorrência (null = sem fim)

  exceptions EventException[]

  @@index([companyId, startAt])
  @@index([categoryId])
  @@map("schedule_events")
}

// Desvios pontuais de uma ocorrência específica de um evento recorrente —
// pular ou editar só aquele dia, sem afetar o resto da série e sem criar
// uma linha por ocorrência futura.
model EventException {
  id String @id @default(uuid())

  eventId String
  event   ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Data/hora de início ORIGINAL da ocorrência afetada (antes de qualquer
  // edição) — é a chave que casa a exceção com a ocorrência gerada pelo
  // RRULE na hora da expansão.
  occurrenceDate DateTime

  action EventExceptionAction

  // Quando action = MODIFIED: campos sobrescritos nessa ocorrência
  // (title/startAt/endAt/visibility). Ignorado quando CANCELLED.
  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, occurrenceDate])
  @@index([eventId])
  @@map("schedule_event_exceptions")
}

model Integration {
  id          String              @id @default(uuid())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  provider    IntegrationProvider
  name        String
  description String?
  status      IntegrationStatus   @default(ACTIVE)
  connectedAt DateTime?
  revokedAt   DateTime?

  config      Json    @default("{}") // filtros, regras, preferências
  credentials Json? // tokens, secrets (criptografar no app)
  externalId  String? // ex: github org id, slack team id
  externalUrl String? // link direto para a integração

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([provider, externalId, userId])
  @@map("integrations")
}

enum IntegrationProvider {
  GITHUB
  VERCEL
  GOOGLE
  SLACK
  NOTION
  FIGMA
  CUSTOM
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
  ERROR
  REVOKED
}

model Notification {
  id          String           @id @default(uuid())
  createdAt   DateTime         @default(now())
  type        NotificationType
  title       String
  description String
  actionUrl   String?
  read        Boolean          @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  MENTION
  PR
  DEPLOY
  MEETING
  TASK
  MESSAGE
}

model CallSession {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  endedAt   DateTime?

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  startedById String
  startedBy   User   @relation("CallSessionStarter", fields: [startedById], references: [id])

  transcriptSegments TranscriptSegment[]
  agentActionLogs    AgentActionLog[]

  @@index([roomId, createdAt])
  @@map("call_sessions")
}

model TranscriptSegment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  callSessionId String
  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  roomId String // desnormalizado para queries diretas por Room sem join

  userId String
  user   User   @relation(fields: [userId], references: [id])

  text       String
  isFinal    Boolean @default(true) // Deepgram manda interim + final; só persistimos final
  startMs    Int
  endMs      Int
  confidence Float?

  @@index([callSessionId, startMs])
  @@index([roomId, createdAt])
  @@map("transcript_segments")
}

model AgentActionLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  callSessionId String?
  callSession   CallSession? @relation(fields: [callSessionId], references: [id], onDelete: SetNull)

  roomId String

  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  triggeredByUserId String?
  triggeredBy       User?   @relation(fields: [triggeredByUserId], references: [id])

  trigger AgentTriggerType

  input  String
  output String

  toolName   String? // null se só respondeu texto, sem tool
  toolArgs   Json?
  toolResult Json?

  status       AgentActionStatus @default(SUCCESS)
  errorMessage String?

  @@index([roomId, createdAt])
  @@index([callSessionId])
  @@index([agentId])
  @@map("agent_action_logs")
}

enum AgentTriggerType {
  VOICE_COMMAND
  CHAT_MESSAGE
  AUTONOMOUS
}

enum AgentActionStatus {
  SUCCESS
  ERROR
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskActivityType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNEE_ADDED
  ASSIGNEE_REMOVED
  DUE_DATE_CHANGED
  MOVED
  COMMENTED
  ATTACHMENT_ADDED
  CHECKLIST_ITEM_TOGGLED
  DESCRIPTION_CHANGED
  ARCHIVED
  DELETED
}

model Task {
  id               String       @id @default(uuid())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  title            String
  description      String?
  status           TaskStatus   @default(TODO)
  priority         TaskPriority @default(MEDIUM)
  position         Float        @default(0)
  startDate        DateTime?
  dueDate          DateTime?
  estimatedMinutes Int?
  recurrenceRule   Json?
  labels           String[]     @default([])
  githubPR         String?
  isArchived       Boolean      @default(false)

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  categoryId  String?
  category    RoomCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User       @relation("TaskCreator", fields: [createdById], references: [id])
  parentId    String?
  parent      Task?      @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]     @relation("TaskSubtasks")

  assignees   TaskAssignee[]
  watchers    TaskWatcher[]
  checklists  TaskChecklist[]
  comments    TaskComment[]
  attachments TaskAttachment[]
  activities  TaskActivity[]

  @@index([companyId, status])
  @@index([companyId, workspaceId])
  @@index([categoryId])
  @@index([parentId])
  @@index([dueDate])
  @@map("tasks")
}

model TaskAssignee {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskWatcher {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TaskWatcher", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_watchers")
}

model TaskChecklist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  order     Int      @default(0)

  taskId String
  task   Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items  TaskChecklistItem[]

  @@index([taskId])
  @@map("task_checklists")
}

model TaskChecklistItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  isDone    Boolean  @default(false)
  order     Int      @default(0)

  checklistId String
  checklist   TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("task_checklist_items")
}

model TaskComment {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  content          String
  isEdited         Boolean  @default(false)
  isDeleted        Boolean  @default(false)
  mentionedUserIds String[] @default([])

  taskId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("TaskCommentAuthor", fields: [authorId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskAttachment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  fileName  String
  fileUrl   String
  publicId  String
  fileType  String?
  fileSize  Int?

  taskId       String
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User   @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  /// Espelho em Documentos — cascade remove o Document quando o anexo some.
  document Document?

  @@index([taskId])
  @@map("task_attachments")
}

model TaskActivity {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  type      TaskActivityType
  actorId   String?
  actor     User?            @relation("TaskActivityActor", fields: [actorId], references: [id])
  fromValue Json?
  toValue   Json?

  @@index([taskId, createdAt])
  @@map("task_activities")
}

model Folder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  parentId String?
  parent   Folder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderChildren")

  createdById String
  createdBy   User   @relation("FolderCreator", fields: [createdById], references: [id])

  documents Document[]

  @@index([companyId, parentId])
  @@index([companyId, workspaceId])
  @@map("folders")
}

model Document {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fileName  String
  fileUrl   String
  publicId  String
  fileType  String?
  fileSize  Int?

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // Categoria da empresa a que este documento está associado — quando o
  // arquivo vem de uma mensagem de chat (chatMessageId), é herdada
  // automaticamente da categoria da sala do canal; upload manual pela
  // página Documentos também pode setar.
  categoryId String?
  category   RoomCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User   @relation("DocumentUploader", fields: [uploadedById], references: [id])

  /// Quando o arquivo veio de um anexo de tarefa (mesmo publicId/arquivo no Cloudinary).
  taskAttachmentId String?         @unique
  taskAttachment   TaskAttachment? @relation(fields: [taskAttachmentId], references: [id], onDelete: Cascade)

  /// Quando o arquivo veio de uma mensagem enviada num canal de texto.
  chatMessageId String?      @unique
  chatMessage   ChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)

  @@index([companyId, folderId])
  @@index([companyId, workspaceId])
  @@index([categoryId])
  @@map("documents")
}
