generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  email     String   @unique
  password  String?
  picture   String?

  companies Company[]

  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  cnpj      String?  @unique
  picture   String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  rooms Room[]

  @@map("companies")
}

model RoomCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emoji     String
  title     String

  rooms Room[]

  @@map("room_categories")
}

model Room {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  type      RoomTypes @default(OFFICE)
  title     String

  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  categoryId String?
  category   RoomCategory? @relation(fields: [categoryId], references: [id])

  @@map("rooms")
}

enum RoomTypes {
  OFFICE
  MEETING
  CHAT
  ADVISORY
}
